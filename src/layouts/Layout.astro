---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
}

const { title, description = "By builders, for builders.", bodyClass = "wp-singular post-template-default single single-post wp-theme-command-line" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Command Line</title>
  <meta name="description" content={description} />
  
  <link rel="icon" href="/favicon.png" sizes="32x32" />
</head>
<body class={bodyClass}>
  <script is:inline>
    // Inline blocking script to apply dark mode class before page render
    (function() {
      const theme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      if (theme === 'dark') {
        document.body.classList.add('dark');
      } else {
        document.body.classList.remove('dark');
      }
    })();
  </script>
  
  <a class="skip-link" href="#main-content">Skip to main content</a>
  
  <Header />

  <slot />

  <Footer />
</body>
</html>
