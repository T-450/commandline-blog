---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found" bodyClass="wp-singular post-template-default single single-post wp-theme-command-line">
  <main id="main-content">
    <div class="hero" style="text-align: center; padding: 120px 20px; max-width: 800px; margin: 0 auto;">
      <h1 style="font-size: 8rem; margin-bottom: 10px; font-family: var(--font-sans); font-weight: 500; line-height: 1; letter-spacing: -0.04em;">404</h1>
      <p style="font-size: 1.25rem; margin-bottom: 30px; font-family: var(--font-mono); text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-muted);">
        Page Not Found
      </p>
      <p style="font-size: 1.1rem; max-width: 500px; margin: 0 auto 40px; font-family: var(--font-sans); line-height: 1.6; color: var(--color-muted);">
        The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.
      </p>
      <a 
        href={`${import.meta.env.BASE_URL}/`} 
        class="filter-subscribe-btn" 
        style="opacity: 1; transform: none; display: inline-flex; margin-top: 0; cursor: pointer;"
      >
        Back to Home
      </a>
    </div>
  </main>
</Layout>
